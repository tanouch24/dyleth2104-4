<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DYLETH — Bouclier Numérique Personnel · Protection 7-en-1</title>
<meta name="description" content="DYLETH : bouclier numérique personnel. 7 modules de protection contre appels, SMS, emails, URLs et WiFi. Développée en France, RGPD natif, conçue pour renforcer votre sécurité numérique.">
<link rel="canonical" href="https://dyleth.com/">
<meta property="og:type" content="website">
<meta property="og:title" content="DYLETH — Bouclier Numérique Personnel">
<meta property="og:description" content="Protection numérique 7-en-1. Gratuit sans engagement. Développée en France.">
<meta property="og:url" content="https://dyleth.com/">
<meta property="og:locale" content="fr_FR">
<link rel="icon" type="image/svg+xml" href="favicon.svg">
<link rel="apple-touch-icon" href="favicon.svg">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css">
<style>

/* ════════════════════════════════════════
   STYLES SPÉCIFIQUES À L'ACCUEIL
════════════════════════════════════════ */

/* Ticker */
.ticker {
  position: relative; z-index: 1; margin-top: 64px;
  background: rgba(10,132,255,0.06);
  border-bottom: 1px solid rgba(10,132,255,0.15);
  padding: 10px 0; overflow: hidden;
}
.ticker-inner {
  display: flex; gap: 80px; white-space: nowrap;
  animation: tickerMove 40s linear infinite;
}
.ticker-item {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 11px; font-weight: 600; letter-spacing: 1.5px;
  text-transform: uppercase; color: rgba(96,179,255,0.9);
}
.ticker-icon { font-size: 10px; opacity: .7; }
@keyframes tickerMove { from{transform:translateX(0)} to{transform:translateX(-50%)} }

/* HERO */
.hero {
  position: relative; z-index: 1;
  min-height: calc(100vh - 88px);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 80px 24px 80px;
  text-align: center;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(10,132,255,0.1);
  border: 1px solid rgba(10,132,255,0.3);
  border-radius: 100px; padding: 7px 18px;
  font-size: 12px; font-weight: 600; color: #60B3FF;
  letter-spacing: 1px; text-transform: uppercase;
  margin-bottom: 32px;
  animation: riseUp .7s .1s ease both;
}
.badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--blue); animation: livePulse 2s infinite; }
@keyframes livePulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.4)} }

.hero-title {
  font-size: clamp(42px, 7.5vw, 88px);
  font-weight: 900; line-height: 1.05;
  letter-spacing: -2px; margin-bottom: 10px;
  animation: riseUp .7s .25s ease both;
}
.hero-title em {
  font-style: normal;
  background: linear-gradient(135deg, var(--blue) 0%, #5AC8FA 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.hero-tagline {
  font-size: clamp(18px, 3vw, 26px); font-weight: 300;
  color: var(--white-60); letter-spacing: -.3px;
  margin-bottom: 48px;
  animation: riseUp .7s .35s ease both;
}
.hero-tagline strong { color: var(--white); font-weight: 500; }

.modules-visual {
  display: flex; align-items: center; justify-content: center;
  gap: 10px; flex-wrap: wrap; margin-bottom: 52px;
  animation: riseUp .7s .45s ease both;
}
.mod-chip {
  display: flex; align-items: center; gap: 8px;
  background: var(--white-10); border: 1px solid var(--border);
  border-radius: 12px; padding: 10px 16px;
  font-size: 13px; font-weight: 500; color: var(--white-60);
  transition: all .25s; cursor: default;
}
.mod-chip:hover {
  background: rgba(10,132,255,0.1);
  border-color: rgba(10,132,255,0.4);
  color: var(--white); transform: translateY(-2px);
}
.mod-chip .mod-icon { font-size: 16px; }
.mod-chip.pro {
  border-color: rgba(255,214,10,0.35);
  background: rgba(255,214,10,0.06);
  color: var(--gold);
}
.mod-chip.pro:hover { background: rgba(255,214,10,0.1); border-color: rgba(255,214,10,0.6); }
.chip-pro-badge {
  font-size: 9px; font-weight: 800; letter-spacing: 1px;
  background: var(--gold); color: #000;
  padding: 2px 5px; border-radius: 4px;
}

.cta-wrap {
  display: flex; flex-direction: column; align-items: center; gap: 14px;
  animation: riseUp .7s .55s ease both;
}
.btn-hero {
  display: inline-flex; align-items: center; gap: 12px;
  background: var(--blue); color: #fff;
  font-size: 17px; font-weight: 700; letter-spacing: -.2px;
  padding: 18px 44px; border-radius: 100px; border: none;
  cursor: pointer; text-decoration: none; position: relative; overflow: hidden;
  box-shadow: 0 0 20px var(--blue-glow);
  transition: all .25s;
}
.btn-hero:hover { transform: scale(1.04); box-shadow: 0 8px 40px var(--blue-glow); background: #1A8FFF; }
.btn-arrow { font-size: 20px; transition: transform .2s; }
.btn-hero:hover .btn-arrow { transform: translateX(4px); }

.cta-micro {
  display: flex; align-items: center; gap: 20px;
  font-size: 12px; color: var(--white-30);
  letter-spacing: .3px; flex-wrap: wrap; justify-content: center;
}
.cta-micro-item { display: flex; align-items: center; gap: 5px; }
.cta-micro-icon { color: var(--green); font-size: 11px; }

.stats-bar {
  display: flex; gap: 0;
  border: 1px solid var(--border-b); border-radius: 18px;
  background: rgba(8,12,24,0.7); backdrop-filter: blur(20px);
  overflow: hidden; margin-top: 52px;
  animation: riseUp .7s .65s ease both;
}
.stat { padding: 20px 32px; border-right: 1px solid var(--border-b); text-align: center; }
.stat:last-child { border-right: none; }
.stat-number { font-size: 30px; font-weight: 800; letter-spacing: -1px; display: block; line-height: 1; }
.stat-number.green { color: var(--green); }
.stat-number.blue { color: var(--blue); }
.stat-number.gold { color: var(--gold); }
.stat-label {
  font-size: 10px; font-weight: 500; letter-spacing: 1px;
  text-transform: uppercase; color: var(--white-30);
  display: block; margin-top: 5px;
}
@keyframes riseUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }

/* ═══ SECTION COMMUNE ═══ */
.section-eyebrow {
  font-size: 11px; font-weight: 600; letter-spacing: 3px;
  text-transform: uppercase; opacity: .8; margin-bottom: 24px;
}
.section-eyebrow.blue { color: var(--blue); }
.section-eyebrow.green { color: var(--green); }
.section-eyebrow.gold { color: var(--gold); }

.section-title {
  font-size: clamp(30px, 5vw, 52px); font-weight: 800;
  letter-spacing: -1.5px; line-height: 1.1; margin-bottom: 16px;
}
.section-title em { font-style: normal; }
.section-title em.blue { color: var(--blue); }
.section-title em.green { color: var(--green); }

.section-sub {
  font-size: 17px; font-weight: 300; color: var(--white-60);
  max-width: 560px; margin: 0 auto 70px; line-height: 1.7;
}
.section-sub strong { color: var(--white); font-weight: 500; }
.section-link {
  display: inline-flex; align-items: center; gap: 8px;
  color: var(--blue); font-size: 14px; font-weight: 600;
  text-decoration: none; margin-top: 20px; transition: gap .2s;
}
.section-link:hover { gap: 14px; }

/* CONSTAT */
.section-shock {
  position: relative; z-index: 1;
  padding: 120px 24px;
  background: linear-gradient(180deg, transparent 0%, rgba(10,132,255,0.04) 50%, transparent 100%);
  border-top: 1px solid var(--border-b);
  border-bottom: 1px solid var(--border-b);
  text-align: center;
}
.shock-title {
  font-size: clamp(32px, 5vw, 56px); font-weight: 800;
  letter-spacing: -1.5px; line-height: 1.1;
  margin-bottom: 20px; max-width: 900px; margin-left: auto; margin-right: auto;
}
.shock-sub {
  font-size: 18px; font-weight: 300; color: var(--white-60);
  max-width: 620px; margin: 0 auto 60px; line-height: 1.7;
}
.shock-sub strong { color: var(--white); font-weight: 500; }
.numbers-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 16px; max-width: 1100px; margin: 0 auto 50px;
}
.number-card {
  background: var(--white-10); border: 1px solid var(--border);
  border-radius: 20px; padding: 32px 24px;
  text-align: left; transition: all .3s;
}
.number-card:hover {
  border-color: rgba(10,132,255,0.4);
  background: rgba(10,132,255,0.05);
  transform: translateY(-3px);
}
.number-big {
  font-size: 44px; font-weight: 900; letter-spacing: -1.5px;
  color: var(--blue); line-height: 1; margin-bottom: 10px;
}
.number-label { font-size: 14px; font-weight: 500; color: var(--white); margin-bottom: 12px; line-height: 1.4; }
.number-source { font-size: 11px; color: var(--white-30); letter-spacing: .3px; }
.sources-note {
  font-size: 13px; color: var(--white-30);
  max-width: 640px; margin: 0 auto; line-height: 1.6;
}

/* MODULES */
.section-modules {
  position: relative; z-index: 1;
  padding: 120px 24px; text-align: center;
}
.modules-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 12px; max-width: 1120px; margin: 0 auto;
}
.module-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 20px; padding: 28px 22px; text-align: center;
  transition: all .3s; position: relative; overflow: hidden;
}
.module-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--blue), transparent);
  opacity: 0; transition: opacity .3s;
}
.module-card:hover { border-color: rgba(10,132,255,0.4); transform: translateY(-4px); }
.module-card:hover::before { opacity: 1; }
.module-card.pro-module { border-color: rgba(255,214,10,0.3); }
.module-card.pro-module::before { background: linear-gradient(90deg, transparent, var(--gold), transparent); }
.module-card.pro-module:hover { border-color: rgba(255,214,10,0.6); }
.module-emoji { font-size: 36px; margin-bottom: 14px; display: block; }
.module-name { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
.module-desc { font-size: 13px; color: var(--white-60); line-height: 1.6; }
.module-free {
  display: inline-block; margin-top: 14px;
  font-size: 10px; font-weight: 700; letter-spacing: 1px;
  color: var(--green); background: var(--green-dim);
  border: 1px solid rgba(48,209,88,0.25); padding: 4px 12px; border-radius: 100px;
}
.module-pro-tag {
  display: inline-block; margin-top: 14px;
  font-size: 10px; font-weight: 800; letter-spacing: 1px;
  color: #000; background: var(--gold);
  padding: 4px 10px; border-radius: 100px;
}

/* COMMENT ÇA MARCHE */
.section-how {
  position: relative; z-index: 1;
  padding: 120px 24px; text-align: center;
  background: linear-gradient(180deg, transparent 0%, rgba(10,132,255,0.04) 50%, transparent 100%);
  border-top: 1px solid var(--border-b);
}
.how-steps {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 2px; max-width: 1000px; margin: 0 auto;
  border: 1px solid var(--border-b); border-radius: 24px; overflow: hidden;
}
.step {
  background: var(--bg2); padding: 40px 32px; text-align: center;
  border-right: 1px solid var(--border-b); transition: background .3s;
}
.step:last-child { border-right: none; }
.step:hover { background: rgba(10,132,255,0.06); }
.step-number {
  width: 36px; height: 36px; border-radius: 50%;
  background: rgba(10,132,255,0.15); border: 1px solid rgba(10,132,255,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 800; color: var(--blue);
  margin: 0 auto 20px;
}
.step-icon { font-size: 34px; margin-bottom: 16px; display: block; }
.step-title { font-size: 15px; font-weight: 700; margin-bottom: 8px; }
.step-desc { font-size: 13px; color: var(--white-60); line-height: 1.6; }

/* BOUCLIER */
.section-shield {
  position: relative; z-index: 1;
  padding: 120px 24px; text-align: center;
}
.shield-visual { position: relative; width: 220px; height: 220px; margin: 0 auto 60px; }
.shield-outer {
  width: 220px; height: 220px;
  border: 1px solid rgba(10,132,255,0.2); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  animation: shieldPulseOuter 3s ease-in-out infinite;
}
.shield-mid {
  width: 160px; height: 160px;
  border: 1px solid rgba(10,132,255,0.35); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  animation: shieldPulseMid 3s .5s ease-in-out infinite;
}
.shield-inner {
  width: 100px; height: 100px;
  background: radial-gradient(circle, rgba(10,132,255,0.25) 0%, rgba(10,132,255,0.05) 100%);
  border: 2px solid var(--blue); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 42px;
  box-shadow: 0 0 30px var(--blue-glow), inset 0 0 20px rgba(10,132,255,0.1);
}
@keyframes shieldPulseOuter { 0%,100%{transform:scale(1);opacity:.5} 50%{transform:scale(1.04);opacity:1} }
@keyframes shieldPulseMid  { 0%,100%{transform:scale(1);opacity:.6} 50%{transform:scale(1.05);opacity:1} }
.shield-features {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px; max-width: 860px; margin: 0 auto 64px;
}
.shield-feat {
  background: var(--white-10); border: 1px solid var(--border);
  border-radius: 20px; padding: 28px 24px; text-align: left; transition: all .3s;
}
.shield-feat:hover { border-color: rgba(10,132,255,0.4); background: rgba(10,132,255,0.07); transform: translateY(-3px); }
.feat-icon { font-size: 26px; margin-bottom: 14px; display: block; }
.feat-title { font-size: 14px; font-weight: 700; margin-bottom: 6px; }
.feat-desc { font-size: 13px; color: var(--white-60); line-height: 1.6; }
.shield-quote {
  font-size: clamp(22px, 3.5vw, 36px); font-weight: 800;
  letter-spacing: -1px; line-height: 1.2;
  max-width: 700px; margin: 0 auto;
}
.shield-quote em { font-style: normal; color: var(--blue); }

/* SECTEURS */
.section-sectors {
  position: relative; z-index: 1;
  padding: 120px 24px; text-align: center;
}
.sectors-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 12px; max-width: 1100px; margin: 0 auto;
}
.sector-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 16px; padding: 22px; text-align: left;
  text-decoration: none; color: var(--white);
  transition: all .3s; display: block;
}
.sector-card:hover {
  border-color: rgba(10,132,255,0.4);
  background: rgba(10,132,255,0.04);
  transform: translateY(-3px);
}
.sector-name { font-size: 14px; font-weight: 700; margin-bottom: 6px; display: flex; align-items: center; justify-content: space-between; }
.sector-arrow { color: var(--blue); font-size: 16px; opacity: 0; transition: opacity .2s; }
.sector-card:hover .sector-arrow { opacity: 1; }
.sector-loss { font-size: 12px; color: var(--white-60); font-weight: 500; }

/* CHARTE */
.section-charter {
  position: relative; z-index: 1;
  padding: 120px 24px; text-align: center;
  background: linear-gradient(180deg, transparent 0%, rgba(48,209,88,0.04) 50%, transparent 100%);
  border-top: 1px solid rgba(48,209,88,0.1);
  border-bottom: 1px solid rgba(48,209,88,0.1);
}
.charter-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 18px; max-width: 1100px; margin: 0 auto;
}
.charter-card {
  background: var(--white-10); border: 1px solid var(--border);
  border-radius: 18px; padding: 32px 28px; text-align: left;
  transition: all .3s;
}
.charter-card:hover { border-color: rgba(48,209,88,0.3); background: rgba(48,209,88,0.03); transform: translateY(-3px); }
.charter-icon { font-size: 30px; margin-bottom: 16px; display: block; }
.charter-title { font-size: 16px; font-weight: 700; margin-bottom: 10px; }
.charter-desc { font-size: 13.5px; color: var(--white-60); line-height: 1.65; }

/* TRUST / RGPD */
.section-trust {
  position: relative; z-index: 1;
  padding: 120px 24px;
}
.trust-inner {
  max-width: 1100px; margin: 0 auto;
  display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start;
}
.trust-left { text-align: left; }
.trust-title {
  font-size: clamp(28px, 4vw, 44px); font-weight: 800;
  letter-spacing: -1.5px; line-height: 1.15; margin-bottom: 20px;
}
.trust-title em { font-style: normal; color: var(--green); }
.trust-desc { font-size: 16px; color: var(--white-60); line-height: 1.75; margin-bottom: 32px; }
.trust-desc strong { color: var(--white); font-weight: 600; }
.trust-badges { display: flex; flex-wrap: wrap; gap: 10px; }
.trust-badge {
  display: flex; align-items: center; gap: 7px;
  background: var(--green-dim); border: 1px solid rgba(48,209,88,0.25);
  border-radius: 100px; padding: 7px 16px;
  font-size: 12px; font-weight: 600; color: var(--green);
  letter-spacing: .3px;
}
.trust-right { display: flex; flex-direction: column; gap: 14px; }
.rgpd-card {
  background: var(--white-10); border: 1px solid var(--border);
  border-radius: 16px; padding: 20px 22px; transition: all .3s;
}
.rgpd-card:hover { border-color: rgba(48,209,88,0.3); background: rgba(48,209,88,0.04); }
.rgpd-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.rgpd-icon { font-size: 18px; }
.rgpd-title { font-size: 13px; font-weight: 700; color: var(--green); letter-spacing: .5px; text-transform: uppercase; }
.rgpd-body { font-size: 13px; color: var(--white-60); line-height: 1.65; }
.rgpd-body strong { color: var(--white); font-weight: 600; }

/* TARIFS */
.section-pricing {
  position: relative; z-index: 1;
  padding: 120px 24px; text-align: center;
  background: linear-gradient(180deg, transparent 0%, rgba(10,132,255,0.04) 50%, transparent 100%);
  border-top: 1px solid var(--border-b);
}
.pricing-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 20px; max-width: 860px; margin: 0 auto;
}
.price-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 24px; padding: 40px 32px; text-align: left;
  position: relative; transition: all .3s;
}
.price-card.featured {
  border-color: rgba(48,209,88,0.4);
  background: linear-gradient(135deg, rgba(48,209,88,0.06), var(--bg2));
  box-shadow: 0 0 40px rgba(48,209,88,0.1);
}
.price-card:hover { transform: translateY(-4px); }
.price-badge {
  position: absolute; top: -12px; left: 32px;
  background: var(--green); color: #000;
  font-size: 10px; font-weight: 800; letter-spacing: 1px;
  padding: 5px 12px; border-radius: 100px;
}
.price-tag { font-size: 12px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; color: var(--white-60); margin-bottom: 16px; }
.price-big { font-size: 52px; font-weight: 900; letter-spacing: -2px; line-height: 1; margin-bottom: 8px; }
.price-big.free { color: var(--green); }
.price-unit { font-size: 15px; color: var(--white-60); margin-bottom: 28px; }
.price-features { list-style: none; padding: 0; margin: 0 0 28px; }
.price-features li {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 14px; color: var(--white); line-height: 1.5;
  padding: 8px 0;
}
.price-check { color: var(--green); font-weight: 800; flex-shrink: 0; margin-top: 2px; }
.price-btn {
  display: block; text-align: center;
  background: var(--white-10); border: 1px solid var(--border);
  border-radius: 14px; padding: 14px 24px;
  font-size: 14px; font-weight: 700; color: var(--white);
  text-decoration: none; transition: all .25s;
}
.price-btn:hover { background: rgba(242,242,247,0.15); }
.price-btn.primary {
  background: var(--blue); border-color: var(--blue); color: #fff;
  box-shadow: 0 0 20px var(--blue-glow);
}
.price-btn.primary:hover { background: #1A8FFF; transform: scale(1.02); }

/* FINAL CTA — STORES avec vrais logos */
.section-final {
  position: relative; z-index: 1;
  padding: 140px 24px; text-align: center;
  background: linear-gradient(180deg, transparent 0%, rgba(10,132,255,0.06) 50%, transparent 100%);
  border-top: 1px solid var(--border-b);
}
.final-title {
  font-size: clamp(36px, 6vw, 72px); font-weight: 900;
  letter-spacing: -2px; line-height: 1.05; margin-bottom: 24px;
}
.final-title em { font-style: normal; color: var(--blue); }
.final-sub {
  font-size: 18px; font-weight: 300; color: var(--white-60);
  max-width: 500px; margin: 0 auto 50px; line-height: 1.7;
}
.store-row {
  display: flex; align-items: center; justify-content: center;
  gap: 16px; flex-wrap: wrap;
}
.store-btn {
  display: inline-flex; align-items: center; gap: 14px;
  background: #000; border: 1px solid rgba(255,255,255,0.2);
  border-radius: 14px; padding: 12px 24px;
  text-decoration: none; color: #fff; transition: all .25s;
  min-width: 200px;
